# ============================================================
# BACKEND ENVIRONMENT CONFIGURATION EXAMPLE
# ============================================================
# Copy this file to .env and update values for your environment

# ============================================================
# APPLICATION CONFIGURATION
# ============================================================
PROJECT_NAME="Time Sheet Management System"
API_V1_STR="/api/v1"
ENVIRONMENT="development"
DEBUG=true

# ============================================================
# SERVER CONFIGURATION
# ============================================================
SERVER_HOST="0.0.0.0"
SERVER_PORT=9079

# ============================================================
# SECURITY CONFIGURATION
# ============================================================
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY="your-secure-random-key-here"
ACCESS_TOKEN_EXPIRE_MINUTES=11520
REFRESH_TOKEN_EXPIRE_MINUTES=43200
ALGORITHM="HS256"

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
MONGODB_HOST="localhost"
MONGODB_PORT=27017
MONGODB_USER="admin"
MONGODB_PASSWORD="password"
MONGODB_DATABASE="timesheet"
MONGODB_AUTH_SOURCE="admin"
DATABASE_URL="mongodb://admin:password@localhost:27017/timesheet?authSource=admin"

# ============================================================
# CORS CONFIGURATION
# ============================================================
CORS_ORIGINS="http://localhost:9078,http://localhost:5173"
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS="GET,POST,PUT,DELETE,OPTIONS,PATCH"
CORS_ALLOW_HEADERS="Content-Type,Authorization"

# ============================================================
# INITIAL SUPERADMIN CONFIGURATION
# ============================================================
FIRST_SUPERUSER="admin@example.com"
FIRST_SUPERUSER_PASSWORD="ChangeMe@123456"

# ============================================================
# EMAIL CONFIGURATION
# ============================================================
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="your-email@example.com"
SMTP_PASSWORD="your-app-password"
EMAILS_FROM_EMAIL="noreply@example.com"
EMAILS_FROM_NAME="Time Sheet System"

# ============================================================
# LOGGING CONFIGURATION
# ============================================================
LOG_LEVEL="INFO"
LOG_FORMAT="json"

# ============================================================
# CACHE CONFIGURATION
# ============================================================
CACHE_TTL=3600
